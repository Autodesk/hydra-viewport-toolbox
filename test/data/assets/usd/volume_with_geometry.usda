#usda 1.0
(
    doc = "Opaque geometry with a Volume prim for WBOIT volume fallback testing"
)

def Xform "Root"
{
    # Back rectangle (opaque) - Red
    # Offset to bottom-right and Z = 1.0
    def Mesh "OpaqueRect" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        int[] faceVertexCounts = [4]
        int[] faceVertexIndices = [3, 2, 1, 0]
        point3f[] points = [
            (-1.0, -1.0, 0.0),
            (1.0, -1.0, 0.0),
            (1.0, 1.0, 0.0),
            (-1.0, 1.0, 0.0)
        ]
        uniform token subdivisionScheme = "none"
        double3 xformOp:translate = (0.5, -0.5, 1.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </Root/Materials/OpaqueMaterial>
    }

    # Front rectangle (opaque) - Blue
    # Offset to top-left and Z = -1.0
    def Mesh "FrontOpaqueRect" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        int[] faceVertexCounts = [4]
        int[] faceVertexIndices = [3, 2, 1, 0]
        point3f[] points = [
            (-1.0, -1.0, 0.0),
            (1.0, -1.0, 0.0),
            (1.0, 1.0, 0.0),
            (-1.0, 1.0, 0.0)
        ]
        uniform token subdivisionScheme = "none"
        double3 xformOp:translate = (-0.5, 0.5, -1.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </Root/Materials/FrontMaterial>
    }

    # Volume prim to exercise the volume render task path with WBOIT.
    # The field intentionally has no file path so no volume geometry renders, validating
    # that the WBOIT fallback (HdxRenderTask instead of HdxOitVolumeRenderTask) handles
    # missing volume data gracefully without errors.
    def Volume "TestVolume"
    {
        float3[] extent = [(-0.5, -0.5, -0.5), (0.5, 0.5, 0.5)]
        double3 xformOp:translate = (0.0, 0.0, 0.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        rel field:density = </Root/TestVolume/Density>

        def OpenVDBAsset "Density"
        {
            token fieldName = "density"
        }
    }

    def Scope "Materials"
    {
        def Material "OpaqueMaterial"
        {
            token outputs:surface.connect = </Root/Materials/OpaqueMaterial/PreviewSurface.outputs:surface>

            def Shader "PreviewSurface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.9, 0.2, 0.2)
                float inputs:opacity = 1.0
                token outputs:surface
            }
        }

        def Material "FrontMaterial"
        {
            token outputs:surface.connect = </Root/Materials/FrontMaterial/PreviewSurface.outputs:surface>

            def Shader "PreviewSurface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.2, 0.5, 0.8)
                float inputs:opacity = 1.0
                token outputs:surface
            }
        }
    }
}
